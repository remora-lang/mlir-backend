fun
  v_4 (x_45 : [2i64]i32,
       y_46 : [2i64]i32)
  : {[2i64]i32} = {
  let {v_3 : [2i64]i32} =
    map(2i64,
        {x_45, y_46},
        \ {v_0 : i32,
           v_1 : i32}
          : {i32} ->
          let {v_2 : i32} =
            add32(v_0, v_1)
          in {v_2})
  in {v_3}
}

entry("main",
      {},
      {[]i32})
  entry_main ()
  : {[2i64]i32} = {
  let {v_5 : [2i64]i32} =
    [1i32, 2i32] : []i32
  let {v_6 : [2i64]i32} =
    [2i32, 4i32] : []i32
  let {v_7 : [2i64]i32} =
    apply v_4(v_5, v_6)
    : {[2i64]i32}
  in {v_7}
}