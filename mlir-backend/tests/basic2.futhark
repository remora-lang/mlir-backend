entry("main",
      {},
      {[]i32})
  entry_main ()
  : {[2i64]i32} = {
  let {v_0 : [2i64]i32} =
    [1i32, 2i32] : []i32
  let {v_1 : [2i64]i32} =
    [3i32, 4i32] : []i32
  let {v_5 : [2i64]i32} =
    map(2i64,
        {v_0, v_1},
        \ {v_2 : i32,
           v_3 : i32}
          : {i32} ->
          let {v_4 : i32} =
            add32(v_2, v_3)
          in {v_4})
  in {v_5}
}