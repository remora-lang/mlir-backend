fun
  add-int-vec (x_50 : [3i64]i32,
               y_51 : [3i64]i32)
  : {[3i64]i32} = {
  let {v_3 : [3i64]i32} =
    map(3i64,
        {x_50, y_51},
        \ {v_0 : i32,
           v_1 : i32}
          : {i32} ->
          let {v_2 : i32} =
            add32(v_0, v_1)
          in {v_2})
  in {v_3}
}

entry("main",
      {},
      {[]i32})
  entry_main ()
  : {[3i64]i32} = {
  let {v_4 : [3i64]i32} =
    [1i32, 2i32, 3i32] : []i32
  let {v_5 : [3i64]i32} =
    [4i32, 5i32, 6i32] : []i32
  let {v_6 : [3i64]i32} =
    apply add-int-vec(v_4, v_5)
    : {[3i64]i32}
  in {v_6}
}